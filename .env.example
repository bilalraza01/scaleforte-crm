GITHUB_USER_NAME=
GITHUB_AUTH_KEY=

# Cloudflare R2 — when set, dev switches audit-screenshot uploads from local
# Disk to R2 so the URLs handed to Smartlead are real public CDN URLs.
# Leave blank for local Disk dev.
#
# Cloudflare dashboard → R2 → your bucket:
#   1. Create an R2 API token with Object Read & Write on this bucket only.
#   2. Toggle "Public access" → r2.dev subdomain (or attach a custom domain).
#
# Account-scoped S3 endpoint (one per Cloudflare account, NOT per bucket):
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scaleforte-audits

# Public host where the bucket is served. Either:
#   r2.dev managed:  https://pub-<id>.r2.dev
#   custom domain:   https://audits.scaleforte.com
R2_PUBLIC_URL_HOST=

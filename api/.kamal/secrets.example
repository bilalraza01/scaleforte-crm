# Copy this file to .kamal/secrets, fill in the placeholders, and never commit it.
# .kamal/secrets is bash-evaluated by Kamal each time you invoke it, so $(cat …)
# and ${VAR} substitution both work.
#
# What goes where:
#   KAMAL_REGISTRY_PASSWORD  → Docker Hub access token (NOT your account password).
#                              Create at https://hub.docker.com/settings/security
#   POSTGRES_PASSWORD        → fresh random password you generate once.
#                              Save it somewhere durable (1Password etc.) — losing it
#                              means losing the DB unless you also keep the volume.
#   RAILS_MASTER_KEY         → already on disk at config/master.key.
#   ACTIVE_RECORD_ENCRYPTION_*→ copy from your local .env / docker-compose.yml.
#   R2_*                     → copy from project-root .env.

KAMAL_REGISTRY_PASSWORD=REPLACE_WITH_DOCKERHUB_ACCESS_TOKEN

# Postgres
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_LONG_STRING

# Rails
RAILS_MASTER_KEY=$(cat config/master.key)

# DB + cache URLs — accessories are reachable inside the kamal Docker network
# by container name: <service>-<accessory>.
DATABASE_URL=postgres://scaleforte:${POSTGRES_PASSWORD}@scaleforte-crm-api-postgres:5432/scaleforte_crm_production
REDIS_URL=redis://scaleforte-crm-api-redis:6379/0

# Active Record encryption — these MUST match what you used to encrypt existing
# rows. Copy from your .env / docker-compose.yml.
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=REPLACE
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=REPLACE
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=REPLACE

# Cloudflare R2 — copy from project-root .env.
R2_ACCESS_KEY_ID=REPLACE
R2_SECRET_ACCESS_KEY=REPLACE

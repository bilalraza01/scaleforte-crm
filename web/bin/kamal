#!/usr/bin/env bash
# Wrapper around the globally-installed kamal gem — same setup as
# api/bin/kamal but cd's to web/ so kamal finds web/config/deploy.yml.
# See api/bin/kamal for the full rationale on each env knob.
set -e
cd "$(dirname "$0")/.."

# shellcheck disable=SC1090
source "$HOME/.bashrc" 2>/dev/null || true

export GEM_HOME=/home/bilal-raza/.rvm/rubies/ruby-3.1.0/lib/ruby/gems/3.1.0
export GEM_PATH=$GEM_HOME
unset BUNDLE_BIN_PATH BUNDLE_GEMFILE RUBY_VERSION

export PATH=/home/bilal-raza/.rvm/rubies/ruby-3.1.0/bin:/snap/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Snap-Docker can only read non-hidden $HOME paths — keep TMPDIR visible.
export TMPDIR="$HOME/kamal-tmp"
mkdir -p "$TMPDIR"

exec /home/bilal-raza/.rvm/rubies/ruby-3.1.0/bin/kamal "$@"
